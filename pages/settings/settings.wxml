<!-- pages/settings/settings.wxml - 设置页 -->
<view class="settings-page">

  <!-- 数据统计 -->
  <view class="stats-card">
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-number">{{credentialCount}}</text>
        <text class="stat-label">凭证总数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number">{{lastModified}}</text>
        <text class="stat-label">最后更新</text>
      </view>
    </view>
  </view>

  <!-- 安全设置 -->
  <view class="section-title">安全设置</view>
  <view class="settings-card">
    <view class="set-row">
      <view class="set-info">
        <text class="set-label">自动锁定</text>
        <text class="set-desc">App 切换后台后自动锁定</text>
      </view>
      <view class="set-value-row">
        <picker
          mode="selector"
          range="{{lockTimeOptions}}"
          range-key="label"
          value="{{lockTimeIndex}}"
          bindchange="onLockTimeChange"
        >
          <text class="picker-value">{{lockTimeOptions[lockTimeIndex].label}}</text>
        </picker>
        <text class="set-arrow">›</text>
      </view>
    </view>

    <view class="set-row">
      <view class="set-info">
        <text class="set-label">面容/指纹解锁</text>
        <text class="set-desc">使用生物识别快速解锁</text>
      </view>
      <switch
        checked="{{biometricEnabled}}"
        bindchange="onBiometricToggle"
        color="#1D9E75"
      />
    </view>

    <view class="set-row">
      <view class="set-info">
        <text class="set-label">修改主密码</text>
        <text class="set-desc">更换用于加密数据的主密码</text>
      </view>
      <text class="set-arrow" bindtap="changeMasterPassword">›</text>
    </view>

    <view class="set-row">
      <view class="set-info">
        <text class="set-label">暗色模式</text>
        <text class="set-desc">适配深色主题（即将推出）</text>
      </view>
      <switch
        checked="{{darkMode}}"
        disabled
        color="#1D9E75"
      />
    </view>
  </view>

  <!-- 分类标签管理 -->
  <view class="section-title">分类标签管理</view>
  <view class="settings-card">
    <view class="set-row cat-row" wx:for="{{customCategories}}" wx:key="key">
      <view class="set-info cat-info">
        <text class="cat-icon">{{item.icon}}</text>
        <view class="cat-text">
          <text class="set-label">{{item.label}}</text>
          <text class="set-desc cat-key">{{item.key}}</text>
        </view>
      </view>
      <view class="cat-actions">
        <text class="cat-action edit" bindtap="editCategory" data-key="{{item.key}}">✎</text>
        <text class="cat-action delete" bindtap="confirmDeleteCategory" data-key="{{item.key}}" data-label="{{item.label}}">✕</text>
      </view>
    </view>

    <!-- 新增分类入口 -->
    <view class="set-row add-cat-row" bindtap="showAddCategory">
      <view class="set-info">
        <text class="add-cat-label">+ 添加新分类</text>
      </view>
    </view>

    <!-- 恢复默认 -->
    <view class="set-row reset-row" bindtap="confirmResetCategories">
      <view class="set-info">
        <text class="set-label" style="color: #EF9F27;">恢复默认分类</text>
        <text class="set-desc">删除自定义分类，恢复系统默认</text>
      </view>
      <text class="set-arrow" style="color: #EF9F27;">›</text>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="section-title">数据管理</view>
  <view class="settings-card">
    <view class="set-row">
      <view class="set-info">
        <text class="set-label">存储空间</text>
        <text class="set-desc">当前 {{storageSize}}</text>
      </view>
    </view>

    <view class="set-row">
      <view class="set-info">
        <text class="set-label">版本</text>
        <text class="set-desc">当前 v1.0.0</text>
      </view>
    </view>
  </view>

  <!-- 危险操作 -->
  <view class="section-title" style="color: var(--color-danger);">危险操作</view>
  <view class="settings-card danger-card">
    <view class="set-row" bindtap="confirmClearAll">
      <view class="set-info">
        <text class="set-label" style="color: var(--color-danger);">清空所有数据</text>
        <text class="set-desc">删除全部凭证，此操作不可恢复</text>
      </view>
      <text class="set-arrow" style="color: var(--color-danger);">›</text>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section-title">关于</view>
  <view class="settings-card">
    <view class="set-row" bindtap="showPrivacyPolicy">
      <view class="set-info">
        <text class="set-label">隐私政策</text>
      </view>
      <text class="set-arrow">›</text>
    </view>

    <view class="set-row" bindtap="showUserAgreement">
      <view class="set-info">
        <text class="set-label">用户协议</text>
      </view>
      <text class="set-arrow">›</text>
    </view>
  </view>

  <!-- 清空确认弹窗 -->
  <view class="modal-overlay" wx:if="{{showClearModal}}">
    <view class="modal-content">
      <view class="modal-icon">🛑</view>
      <view class="modal-title">清空所有数据</view>
      <view class="modal-desc">
        此操作将永久删除所有存储的凭证，且无法恢复。确定要继续吗？
      </view>
      <view class="modal-desc warning">
        此操作不可恢复，请确认已通过云同步备份数据。
      </view>
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="cancelClearAll">取消</button>
        <button class="modal-btn confirm" bindtap="doClearAll">确认清空</button>
      </view>
    </view>
  </view>

  <!-- 分类编辑弹窗 -->
  <view class="modal-overlay" wx:if="{{showCategoryModal}}">
    <view class="modal-content cat-modal">
      <view class="modal-title">{{categoryModalTitle}}</view>

      <view class="cat-form">
        <view class="cat-form-item">
          <text class="cat-form-label">名称</text>
          <input
            class="cat-form-input"
            placeholder="输入分类名称（≤6字）"
            maxlength="6"
            value="{{editingCategory.label}}"
            bindinput="onCategoryLabelInput"
          />
        </view>

        <view class="cat-form-item">
          <text class="cat-form-label">图标</text>
          <view class="cat-icon-picker">
            <view
              wx:for="{{iconOptions}}"
              wx:key="*this"
              class="cat-icon-option {{editingCategory.icon === item ? 'picked' : ''}}"
              bindtap="pickCategoryIcon"
              data-icon="{{item}}"
            >
              <text>{{item}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="dismissCategoryModal">取消</button>
        <button class="modal-btn confirm" bindtap="saveCategory">{{categoryModalAction}}</button>
      </view>
    </view>
  </view>

  <!-- 删除分类确认弹窗 -->
  <view class="modal-overlay" wx:if="{{showDeleteCatModal}}">
    <view class="modal-content">
      <view class="modal-icon">🗑️</view>
      <view class="modal-title">删除分类</view>
      <view class="modal-desc">
        确定要删除「{{deletingCategory.label}}」分类吗？
        已使用此分类的凭证将自动归入「其他」。
      </view>
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="cancelDeleteCategory">取消</button>
        <button class="modal-btn confirm" bindtap="doDeleteCategory">确认删除</button>
      </view>
    </view>
  </view>

  <!-- 重置分类确认弹窗 -->
  <view class="modal-overlay" wx:if="{{showResetCatModal}}">
    <view class="modal-content">
      <view class="modal-icon">🔄</view>
      <view class="modal-title">恢复默认分类</view>
      <view class="modal-desc">
        将删除所有自定义分类，恢复系统默认设置。已有凭证的分类关联不受影响。
      </view>
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="cancelResetCategories">取消</button>
        <button class="modal-btn confirm" bindtap="doResetCategories">确认恢复</button>
      </view>
    </view>
  </view>

  <!-- 底部版权 -->
  <view class="footer-copy">
    <text>密锁 v1.0.0 · 本地加密 · 安全无忧</text>
  </view>
</view>
