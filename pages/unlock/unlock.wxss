/* pages/unlock/unlock.wxss - 解锁页样式 */

/* ===== 隐私弹窗 ===== */
.privacy-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 0 var(--space-xl);
}

.privacy-modal {
  width: 100%;
  max-width: 600rpx;
  background: var(--color-card-bg);
  border-radius: var(--radius-xl);
  padding: var(--space-2xl) var(--space-xl);
  animation: modalFadeIn 0.25s ease;
}

@keyframes modalFadeIn {
  from { opacity: 0; transform: scale(0.95) translateY(20rpx); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

.privacy-icon {
  text-align: center;
  font-size: 72rpx;
  margin-bottom: var(--space-md);
}

.privacy-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-primary);
  text-align: center;
  margin-bottom: var(--space-lg);
}

.privacy-body {
  margin-bottom: var(--space-lg);
}

.privacy-summary {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: var(--space-lg);
}

.privacy-summary .highlight {
  color: var(--color-primary);
  font-weight: 600;
}

.privacy-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.privacy-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
}

.privacy-bullet {
  flex-shrink: 0;
  font-size: var(--font-md);
  margin-top: 2rpx;
}

.privacy-item text:last-child {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
  flex: 1;
}

.privacy-links {
  text-align: center;
  margin-bottom: var(--space-lg);
}

.privacy-links text {
  font-size: var(--font-sm);
  color: var(--color-primary);
  text-decoration: underline;
}

.privacy-actions {
  display: flex;
  gap: var(--space-md);
}

.privacy-btn {
  flex: 1;
  height: 80rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.privacy-btn.deny {
  background: var(--color-divider);
  color: var(--color-text-hint);
}

.privacy-btn.accept {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  box-shadow: 0 4rpx 16rpx rgba(83, 74, 183, 0.3);
}

/* ===== 页面主体 ===== */

.unlock-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(180deg, #EEEDFE 0%, #F1EFE8 100%);
  padding: 0 var(--space-xl);
}

/* ===== 顶部装饰区 ===== */
.hero-area {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
  margin-bottom: 60rpx;
}

/* Logo 锁形 */
.logo-container {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: var(--space-xl);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-lock {
  position: relative;
  width: 100rpx;
  height: 120rpx;
}

.lock-shackle {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 56rpx;
  border: 8rpx solid var(--color-primary);
  border-bottom: none;
  border-radius: 30rpx 30rpx 0 0;
}

.lock-body {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 76rpx;
  background: var(--color-primary);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.lock-keyhole {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.keyhole-circle {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--color-accent);
  margin-bottom: 4rpx;
}

.keyhole-rect {
  width: 18rpx;
  height: 24rpx;
  background: var(--color-accent);
  border-radius: 4rpx;
}

/* 应用名 */
.app-name {
  display: flex;
  align-items: baseline;
  margin-bottom: var(--space-sm);
}

.app-name-mi {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--color-primary);
}

.app-name-suo {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--color-primary-text);
}

.app-subtitle {
  font-size: var(--font-md);
  color: var(--color-text-hint);
  letter-spacing: 2rpx;
}

/* ===== 密码输入区 ===== */
.input-area {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.input-label {
  font-size: var(--font-lg);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-xl);
  text-align: center;
}

.password-input-row {
  width: 100%;
  display: flex;
  align-items: center;
  background: var(--color-card-bg);
  border-radius: var(--radius-lg);
  padding: 0 var(--space-lg);
  box-shadow: var(--shadow-md);
  margin-bottom: var(--space-md);
}

.password-input {
  flex: 1;
  height: 96rpx;
  font-size: var(--font-xl);
  color: var(--color-text-primary);
  letter-spacing: 4rpx;
}

.input-placeholder {
  color: var(--color-text-hint);
  letter-spacing: 0;
}

.eye-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  opacity: 0.6;
}
.eye-toggle:active {
  opacity: 1;
}

.error-message {
  width: 100%;
  padding: var(--space-sm) var(--space-md);
  background: var(--color-danger-light);
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-md);
}

.error-message text {
  font-size: var(--font-sm);
  color: var(--color-danger);
}

.attempts-hint {
  font-size: var(--font-sm);
  color: var(--color-warning);
  margin-bottom: var(--space-md);
}

/* ===== 跨设备 / 重置入口 ===== */
.reset-entry {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: var(--space-sm);
  margin-bottom: var(--space-lg);
}

.reset-divider {
  width: 80%;
  height: 1rpx;
  background: var(--color-divider);
  margin-bottom: var(--space-lg);
}

.reset-btn {
  padding: var(--space-sm) var(--space-xl);
  background: var(--color-warning-light);
  border: 1rpx solid var(--color-warning);
  border-radius: var(--radius-full);
  margin-bottom: var(--space-sm);
}

.reset-btn text {
  font-size: var(--font-sm);
  color: #8B6914;
  font-weight: 600;
}

.reset-btn:active {
  background: var(--color-warning);
  opacity: 0.9;
}

.reset-btn:active text {
  color: #fff;
}

.reset-hint {
  font-size: 22rpx;
  color: var(--color-text-hint);
  text-align: center;
  line-height: 1.5;
  padding: 0 var(--space-lg);
}

/* ===== 密码规则提示 ===== */
.password-rules {
  margin-top: 12rpx;
  margin-bottom: var(--space-md);
  padding: var(--space-md);
  background: #F5F4FF;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-primary-light);
}

.rule-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
  font-size: var(--font-sm);
}

.rule-item .rule-icon {
  font-size: 22rpx;
  width: 28rpx;
  text-align: center;
  flex-shrink: 0;
}

.rule-pass {
  color: var(--color-accent);
}

.rule-pass .rule-icon {
  color: var(--color-accent);
  font-weight: 700;
}

.rule-fail {
  color: var(--color-text-hint);
}

.rule-tip {
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-top: 6rpx;
  padding-left: 38rpx;
}

/* 解锁按钮 */
.btn-unlock {
  width: 100%;
  height: 96rpx;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-xl);
  font-weight: 700;
  border-radius: var(--radius-lg);
  border: none;
  margin-top: var(--space-md);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(83, 74, 183, 0.25);
}
.btn-unlock:active {
  opacity: 0.9;
  transform: scale(0.98);
}
.btn-unlock[disabled] {
  background: #C4C1DE;
  box-shadow: none;
}

/* 生物识别入口 */
.biometric-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: var(--space-xl);
  padding: var(--space-md) var(--space-xl);
  border-radius: var(--radius-full);
  background: var(--color-card-bg);
  box-shadow: var(--shadow-sm);
}

.biometric-entry:active {
  background: #F8F8F6;
}

.fingerprint-icon {
  font-size: var(--font-lg);
  margin-right: var(--space-sm);
}

.biometric-entry text {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
}

/* ===== 底部提示 ===== */
.footer-hint {
  position: absolute;
  bottom: calc(60rpx + constant(safe-area-inset-bottom));
  bottom: calc(60rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
  background: rgba(255, 255, 255, 0.7);
  border-radius: var(--radius-full);
}

.shield-icon {
  font-size: var(--font-md);
  margin-right: var(--space-sm);
}

.footer-text {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
}
