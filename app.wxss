/* app.wxss - 密锁全局样式 */

/* ========== CSS 变量（设计 Token） ========== */
page {
  /* 主色 - 靛蓝紫 */
  --color-primary: #534AB7;
  --color-primary-light: #EEEDFE;
  --color-primary-text: #3C3489;
  --color-primary-bg: #F6F5FD;

  /* 强调色 - 青绿 */
  --color-accent: #1D9E75;
  --color-accent-light: #E1F5EE;

  /* 警告色 - 琥珀 */
  --color-warning: #EF9F27;
  --color-warning-light: #FAECE7;

  /* 危险色 - 红 */
  --color-danger: #A32D2D;
  --color-danger-light: #FCEBEB;

  /* 中性色 */
  --color-page-bg: #F1EFE8;
  --color-card-bg: #FFFFFF;
  --color-border: #D3D1C7;
  --color-divider: #E8E6DF;
  --color-text-primary: #444441;
  --color-text-secondary: #5F5E5A;
  --color-text-hint: #888780;
  --color-text-inverse: #FFFFFF;

  /* 圆角 */
  --radius-sm: 8px;
  --radius-md: 10px;
  --radius-lg: 16px;
  --radius-xl: 20px;
  --radius-full: 9999px;

  /* 间距 */
  --space-xs: 4px;
  --space-sm: 8px;
  --space-md: 12px;
  --space-lg: 16px;
  --space-xl: 20px;
  --space-2xl: 24px;
  --space-3xl: 32px;

  /* 字体 */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-2xl: 40rpx;
  --font-3xl: 48rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.10);

  background-color: var(--color-page-bg);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
    "Hiragino Sans GB", "Microsoft YaHei", "Helvetica Neue", Helvetica, Arial,
    sans-serif;
  font-size: var(--font-md);
  color: var(--color-text-primary);
  line-height: 1.6;
}

/* ========== 通用工具类 ========== */

/* 安全区域底部占位 */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* Flex 布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.flex-col {
  display: flex;
  flex-direction: column;
}
.flex-1 {
  flex: 1;
}
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 文字 */
.text-primary {
  color: var(--color-text-primary);
}
.text-secondary {
  color: var(--color-text-secondary);
}
.text-hint {
  color: var(--color-text-hint);
}
.text-accent {
  color: var(--color-accent);
}
.text-danger {
  color: var(--color-danger);
}
.text-xs {
  font-size: var(--font-xs);
}
.text-sm {
  font-size: var(--font-sm);
}
.text-md {
  font-size: var(--font-md);
}
.text-lg {
  font-size: var(--font-lg);
}
.text-xl {
  font-size: var(--font-xl);
}
.text-bold {
  font-weight: 600;
}

/* 间距 */
.mt-sm { margin-top: var(--space-sm); }
.mt-md { margin-top: var(--space-md); }
.mt-lg { margin-top: var(--space-lg); }
.mt-xl { margin-top: var(--space-xl); }
.mb-sm { margin-bottom: var(--space-sm); }
.mb-md { margin-bottom: var(--space-md); }
.mb-lg { margin-bottom: var(--space-lg); }
.mb-xl { margin-bottom: var(--space-xl); }
.p-sm { padding: var(--space-sm); }
.p-md { padding: var(--space-md); }
.p-lg { padding: var(--space-lg); }
.p-xl { padding: var(--space-xl); }
.px-md { padding-left: var(--space-md); padding-right: var(--space-md); }
.px-lg { padding-left: var(--space-lg); padding-right: var(--space-lg); }
.py-md { padding-top: var(--space-md); padding-bottom: var(--space-md); }
.py-lg { padding-top: var(--space-lg); padding-bottom: var(--space-lg); }

/* 圆角 */
.radius-sm { border-radius: var(--radius-sm); }
.radius-md { border-radius: var(--radius-md); }
.radius-lg { border-radius: var(--radius-lg); }

/* ========== 通用组件样式 ========== */

/* 白色卡片容器 */
.card {
  background: var(--color-card-bg);
  border-radius: var(--radius-md);
  margin: 0 var(--space-lg) var(--space-sm);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

/* 卡片内的行项目 */
.card-row {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  min-height: 88rpx;
  position: relative;
  background: var(--color-card-bg);
}
.card-row + .card-row::before {
  content: '';
  position: absolute;
  top: 0;
  left: var(--space-lg);
  right: 0;
  height: 1rpx;
  background: var(--color-divider);
}
.card-row:active {
  background: #F8F8F6;
}

/* 主按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-lg);
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
  padding: 0 var(--space-xl);
}
.btn-primary:active {
  opacity: 0.85;
}
.btn-primary[disabled] {
  background: #C4C1DE;
  color: rgba(255, 255, 255, 0.7);
}

/* 次要按钮 */
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: var(--color-card-bg);
  color: var(--color-primary);
  font-size: var(--font-lg);
  font-weight: 500;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  padding: 0 var(--space-xl);
}

/* 青绿色强调按钮 */
.btn-accent {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  background: var(--color-accent-light);
  color: var(--color-accent);
  font-size: var(--font-sm);
  font-weight: 600;
  border-radius: var(--radius-sm);
  border: none;
  padding: 0 var(--space-md);
}
.btn-accent:active {
  background: #C8ECE0;
}

/* 危险按钮 */
.btn-danger {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: var(--color-danger-light);
  color: var(--color-danger);
  font-size: var(--font-lg);
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
  padding: 0 var(--space-xl);
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin: var(--space-md) var(--space-lg);
  padding: 0 var(--space-lg);
  height: 72rpx;
  background: var(--color-card-bg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}
.search-bar .search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: var(--space-sm);
  opacity: 0.4;
}
.search-bar input {
  flex: 1;
  height: 100%;
  font-size: var(--font-md);
  color: var(--color-text-primary);
}
.search-bar .search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-divider);
}
.search-bar .search-clear::after {
  content: '✕';
  font-size: 20rpx;
  color: var(--color-text-hint);
}

/* Toast 提示 */
.toast-success {
  background: var(--color-accent) !important;
}
.toast-error {
  background: var(--color-danger) !important;
}

/* 页面级标题 */
.page-title {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--color-primary-text);
  padding: var(--space-lg) var(--space-xl) var(--space-sm);
}

/* 分组标题 */
.section-title {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  padding: var(--space-lg) var(--space-xl) var(--space-sm);
}

/* FAB 悬浮按钮 */
.fab {
  position: fixed;
  right: var(--space-xl);
  bottom: calc(var(--space-3xl) + constant(safe-area-inset-bottom));
  bottom: calc(var(--space-3xl) + env(safe-area-inset-bottom));
  width: 104rpx;
  height: 104rpx;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(83, 74, 183, 0.35);
  z-index: 100;
}
.fab:active {
  transform: scale(0.95);
  opacity: 0.9;
}
.fab .fab-icon {
  color: var(--color-text-inverse);
  font-size: 72rpx;
  line-height: 72rpx;
  font-weight: 400;
  text-align: center;
  margin-top: -6rpx;
  margin-left: 2rpx;
}

/* FAB 管理按钮（左下角） */
.fab-manage {
  position: fixed;
  left: var(--space-xl);
  bottom: calc(var(--space-3xl) + constant(safe-area-inset-bottom));
  bottom: calc(var(--space-3xl) + env(safe-area-inset-bottom));
  width: 104rpx;
  height: 104rpx;
  background: var(--color-card-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}
.fab-manage:active {
  transform: scale(0.95);
  opacity: 0.85;
}
.fab-manage .fab-manage-icon {
  color: var(--color-text-secondary);
  font-size: 68rpx;
  line-height: 68rpx;
  text-align: center;
}
