<!-- components/credential-card/credential-card.wxml -->
<view class="cred-card" bindtap="onTapCard">

  <!-- 左侧图标 -->
  <view class="card-icon" style="background: {{categoryColor}}18;">
    <text>{{credential.icon || '🔒'}}</text>
  </view>

  <!-- 中间信息 -->
  <view class="card-info">
    <view class="card-title-row">
      <text class="card-title">{{credential.title || '未命名'}}</text>
      <view class="card-category" style="color: {{categoryColor}};">
        <text>{{categoryLabel}}</text>
      </view>
    </view>
    <text class="card-username">{{credential.username || '-'}}</text>
    <text class="card-time" wx:if="{{timeAgo}}">{{timeAgo}}</text>
  </view>

  <!-- 右侧操作 -->
  <view class="card-actions">
    <view class="card-action-copy" catchtap="onCopyPassword">
      <text>📋</text>
    </view>
    <view class="card-arrow">
      <text>›</text>
    </view>
  </view>
</view>
