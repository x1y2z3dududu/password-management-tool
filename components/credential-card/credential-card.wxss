/* components/credential-card/credential-card.wxss */

.cred-card {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  background: var(--color-card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: transform 0.1s;
}

.cred-card:active {
  transform: scale(0.985);
  background: #F8F8F6;
}

/* 左侧图标 */
.card-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: var(--space-lg);
  flex-shrink: 0;
}

/* 中间信息 */
.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.card-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.card-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: var(--space-sm);
}

.card-category {
  font-size: var(--font-xs);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-full);
  background: var(--color-page-bg);
  white-space: nowrap;
  flex-shrink: 0;
}

.card-username {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 2rpx;
}

.card-time {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
}

/* 右侧操作 */
.card-actions {
  display: flex;
  align-items: center;
  margin-left: var(--space-md);
  flex-shrink: 0;
}

.card-action-copy {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-accent-light);
  border-radius: var(--radius-sm);
  font-size: var(--font-md);
  margin-right: var(--space-sm);
}

.card-action-copy:active {
  background: #C8ECE0;
}

.card-arrow {
  font-size: var(--font-xl);
  color: var(--color-text-hint);
  font-weight: 300;
}
